{
  "manifest_version": 3,
  "name": "ChromeX - Local Browser MCP",
  "version": "1.0.0",
  "description": "通过 WebSocket 桥接 MCP Server 与 Chrome DevTools Protocol",
  "key": "",
  "permissions": [
    "debugger",
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "history",
    "alarms",
    "tabGroups",
    "clipboardRead",
    "clipboardWrite",
    "nativeMessaging"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ChromeX"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
