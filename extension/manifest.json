{
  "manifest_version": 3,
  "name": "Link2Chrome - Local Browser MCP",
  "version": "1.0.0",
  "description": "通过 WebSocket 桥接 MCP Server 与 Chrome DevTools Protocol",
  "permissions": [
    "debugger",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Link2Chrome"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {}
}
